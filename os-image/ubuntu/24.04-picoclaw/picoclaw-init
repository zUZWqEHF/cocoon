#!/usr/bin/env python3
"""picoclaw-init — First-boot configuration for PicoClaw.

Usage:
    picoclaw-init <api_key> <telegram_bot_token> [provider/model]
    picoclaw-init <api_key> <telegram_bot_token> <model> <provider> [--api-base URL]

Examples:
    picoclaw-init sk-xxx 123456:ABC-DEF                                  # default (openai/gpt-5.4)
    picoclaw-init sk-xxx 123456:ABC-DEF openrouter/qwen/qwen3.5-9b      # OpenRouter
    picoclaw-init sk-xxx 123456:ABC-DEF minimax-m2.5 anthropic --api-base https://my-proxy.com/v1
"""

import argparse
import json
import subprocess
import sys
import time
from pathlib import Path

CONFIG_PATH = Path.home() / ".picoclaw" / "config.json"
SERVICE_NAME = "picoclaw"
GATEWAY_PORT = 18790

# Known provider prefixes in picoclaw model format.
KNOWN_PROVIDERS = {
    "openai",
    "anthropic",
    "groq",
    "deepseek",
    "gemini",
    "zhipu",
    "ollama",
    "openrouter",
    "claude-cli",
}

# Providers that require api_base to be set automatically.
PROVIDER_API_BASE = {
    "openrouter": "https://openrouter.ai/api/v1",
}


def load_config() -> dict:
    if not CONFIG_PATH.exists():
        print(f"Error: config not found at {CONFIG_PATH}", file=sys.stderr)
        sys.exit(1)
    with open(CONFIG_PATH) as f:
        return json.load(f)


def save_config(cfg: dict) -> None:
    CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
    with open(CONFIG_PATH, "w") as f:
        json.dump(cfg, f, indent=2, ensure_ascii=False)
        f.write("\n")


def parse_model_spec(spec: str) -> tuple[str, str]:
    """Parse 'provider/model' into (picoclaw_model_field, model_name).

    picoclaw model field uses 'provider/model-id' format.
    For openrouter, the spec looks like 'openrouter/anthropic/claude-sonnet-4-6',
    meaning provider=openrouter, model=anthropic/claude-sonnet-4-6.
    """
    parts = spec.split("/", 1)
    if len(parts) != 2 or parts[0] not in KNOWN_PROVIDERS:
        print(
            f"Error: '{spec}' is not a valid provider/model format.\n"
            f"Known providers: {', '.join(sorted(KNOWN_PROVIDERS))}",
            file=sys.stderr,
        )
        sys.exit(1)
    return spec, parts[1]


def validate_telegram_token(token: str) -> bool:
    """Telegram bot tokens look like '123456789:ABCdefGHIjklMNOpqrsTUVwxyz'."""
    return ":" in token and token.split(":")[0].isdigit()


def systemctl(*args: str) -> None:
    subprocess.run(["systemctl"] + list(args), check=False)


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="picoclaw-init",
        description="First-boot configuration for PicoClaw.",
    )
    parser.add_argument("api_key", help="API key for the LLM provider")
    parser.add_argument("telegram_token", help="Telegram bot token (from @BotFather)")
    parser.add_argument(
        "model_spec",
        nargs="?",
        default=None,
        help="provider/model (e.g., openai/gpt-5.4) or model name when provider is given",
    )
    parser.add_argument(
        "provider",
        nargs="?",
        default=None,
        help="provider prefix (e.g., anthropic) — use with model name + --api-base",
    )
    parser.add_argument(
        "--api-base",
        default=None,
        help="custom API base URL (e.g., https://my-proxy.com/v1)",
    )
    args = parser.parse_args()

    # Validate API key.
    key = args.api_key.strip()
    if not key or key == "sk-xxx":
        print("Error: a valid API key is required.", file=sys.stderr)
        sys.exit(1)

    # Validate Telegram bot token.
    tg_token = args.telegram_token.strip()
    if not validate_telegram_token(tg_token):
        print(
            "Error: invalid Telegram bot token.\n"
            "Get one from @BotFather on Telegram: https://t.me/BotFather",
            file=sys.stderr,
        )
        sys.exit(1)

    if not CONFIG_PATH.exists():
        print(f"Error: config not found at {CONFIG_PATH}", file=sys.stderr)
        sys.exit(1)

    # Determine model field and display name.
    if args.provider:
        # 3+ arg form: <key> <tg_token> <model> <provider> [--api-base URL]
        model_field = f"{args.provider}/{args.model_spec}"
    elif args.model_spec:
        # 2+ arg form: <key> <tg_token> <provider/model>
        model_field, _ = parse_model_spec(args.model_spec)
    else:
        # Default.
        model_field = "openai/gpt-5.4"

    cfg = load_config()

    # Build model entry. model_name must be "default" to match agents.defaults.model.
    entry = {
        "model_name": "default",
        "model": model_field,
        "api_key": key,
    }

    # Auto-set api_base for known providers; explicit --api-base takes precedence.
    provider_prefix = model_field.split("/", 1)[0]
    if args.api_base:
        entry["api_base"] = args.api_base
    elif provider_prefix in PROVIDER_API_BASE:
        entry["api_base"] = PROVIDER_API_BASE[provider_prefix]

    # Replace or create model_list with the single default entry.
    cfg["model_list"] = [entry]

    # Ensure agent defaults point to "default".
    agents = cfg.setdefault("agents", {})
    defaults = agents.setdefault("defaults", {})
    defaults["model"] = "default"

    # Enable Telegram channel.
    channels = cfg.setdefault("channels", {})
    channels["telegram"] = {
        "enabled": True,
        "token": tg_token,
    }

    save_config(cfg)
    print(f"Configured: model={model_field}")
    if args.api_base or provider_prefix in PROVIDER_API_BASE:
        print(f"  api_base={entry.get('api_base', '')}")
    print(f"  api_key={key[:12]}...{key[-4:]}")
    print(f"  telegram=enabled")

    # Enable and (re)start picoclaw.
    systemctl("daemon-reload")
    systemctl("enable", SERVICE_NAME)
    was_active = (
        subprocess.run(
            ["systemctl", "is-active", "--quiet", SERVICE_NAME], check=False
        ).returncode
        == 0
    )
    if was_active:
        systemctl("restart", SERVICE_NAME)
    else:
        systemctl("start", SERVICE_NAME)

    # Wait briefly and check if service started successfully.
    time.sleep(2)
    if (
        subprocess.run(
            ["systemctl", "is-active", "--quiet", SERVICE_NAME], check=False
        ).returncode
        != 0
    ):
        print("Error: PicoClaw failed to start. Check logs:", file=sys.stderr)
        subprocess.run(
            ["journalctl", "-u", SERVICE_NAME, "-n", "20", "--no-pager"],
            check=False,
        )
        sys.exit(1)

    print("PicoClaw restarted." if was_active else "PicoClaw started.")
    print(f"Done. PicoClaw gateway is running on port {GATEWAY_PORT}.")


if __name__ == "__main__":
    main()
