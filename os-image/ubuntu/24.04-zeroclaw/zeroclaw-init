#!/usr/bin/env python3
"""zeroclaw-init — First-boot configuration for ZeroClaw.

Usage:
    zeroclaw-init <api_key> [provider/model]
    zeroclaw-init <api_key> <model> <provider>

Examples:
    zeroclaw-init sk-xxx                                        # default (openai/gpt-5.4)
    zeroclaw-init sk-xxx openai/gpt-4o-mini                     # OpenAI GPT-4o mini
    zeroclaw-init sk-xxx openrouter/anthropic/claude-sonnet-4-6  # OpenRouter
    zeroclaw-init sk-xxx minimax-m2.5 anthropic-custom:https://my-proxy.com/v1
"""

import argparse
import re
import subprocess
import sys
import time
from pathlib import Path

CONFIG_PATH = Path.home() / ".zeroclaw" / "config.toml"
SERVICE_NAME = "zeroclaw"
GATEWAY_PORT = 42617

# Known simple providers (without custom endpoint URL).
KNOWN_PROVIDERS = {
    "openai", "anthropic", "openrouter",
}


def set_toml_value(path: Path, key: str, value: str) -> None:
    """Replace a top-level TOML key's value. Safe with any special characters."""
    lines = path.read_text().splitlines(keepends=True)
    prefix = key + " = "
    with open(path, "w") as f:
        for line in lines:
            if line.startswith(prefix):
                f.write(f'{key} = "{value}"\n')
            else:
                f.write(line)


def parse_model_spec(spec: str) -> tuple[str, str]:
    """Parse 'provider/model' into (provider, model).

    For simple providers: 'openai/gpt-5.4' -> ('openai', 'gpt-5.4')
    For openrouter: 'openrouter/anthropic/claude-sonnet-4-6' -> ('openrouter', 'anthropic/claude-sonnet-4-6')
    """
    parts = spec.split("/", 1)
    if len(parts) != 2:
        print(f"Error: '{spec}' is not a valid provider/model format.", file=sys.stderr)
        sys.exit(1)

    provider, model = parts[0], parts[1]

    if (
        provider not in KNOWN_PROVIDERS
        and not provider.startswith("anthropic-custom:")
        and not provider.startswith("custom:")
    ):
        print(
            f"Error: unknown provider '{provider}'.\n"
            f"Known providers: {', '.join(sorted(KNOWN_PROVIDERS))}\n"
            f"Custom endpoints: anthropic-custom:<url> or custom:<url>",
            file=sys.stderr,
        )
        sys.exit(1)

    return provider, model


def systemctl(*args: str) -> int:
    return subprocess.run(["systemctl"] + list(args), check=False).returncode


def extract_pairing_code() -> str | None:
    """Extract the 6-digit pairing code from zeroclaw journal logs."""
    try:
        out = subprocess.run(
            ["journalctl", "-u", SERVICE_NAME, "-n", "30", "--no-pager", "-o", "cat"],
            capture_output=True, text=True, check=False,
        ).stdout
        # The pairing code appears as a 6-digit number in a box: │ 485291       │
        match = re.search(r"│\s*(\d{6})\s*│", out)
        if match:
            return match.group(1)
    except Exception:
        pass
    return None


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="zeroclaw-init",
        description="First-boot configuration for ZeroClaw.",
    )
    parser.add_argument("api_key", help="API key for the LLM provider")
    parser.add_argument(
        "model_spec",
        nargs="?",
        default=None,
        help="provider/model (e.g., openai/gpt-5.4) or model name when provider is given as 3rd arg",
    )
    parser.add_argument(
        "provider",
        nargs="?",
        default=None,
        help="provider string (e.g., anthropic-custom:https://my-proxy.com/v1)",
    )
    args = parser.parse_args()

    # Validate API key.
    key = args.api_key.strip()
    if not key or key == "sk-xxx":
        print("Error: a valid API key is required.", file=sys.stderr)
        sys.exit(1)

    if not CONFIG_PATH.exists():
        print(f"Error: config not found at {CONFIG_PATH}", file=sys.stderr)
        sys.exit(1)

    # Determine provider and model.
    if args.provider:
        provider = args.provider
        model = args.model_spec
    elif args.model_spec:
        provider, model = parse_model_spec(args.model_spec)
    else:
        provider = "openai"
        model = "gpt-5.4"

    # Write config.
    set_toml_value(CONFIG_PATH, "api_key", key)
    set_toml_value(CONFIG_PATH, "default_provider", provider)
    set_toml_value(CONFIG_PATH, "default_model", model)

    print(f"Configured: provider={provider}, model={model}")
    print(f"  api_key={key[:12]}...{key[-4:]}")

    # Enable and (re)start zeroclaw.
    systemctl("daemon-reload")
    systemctl("enable", SERVICE_NAME)
    was_active = systemctl("is-active", "--quiet", SERVICE_NAME) == 0
    if was_active:
        systemctl("restart", SERVICE_NAME)
    else:
        systemctl("start", SERVICE_NAME)

    # Wait briefly and check if service started successfully.
    time.sleep(2)
    if systemctl("is-active", "--quiet", SERVICE_NAME) != 0:
        print("Error: ZeroClaw failed to start. Check logs:", file=sys.stderr)
        subprocess.run(
            ["journalctl", "-u", SERVICE_NAME, "-n", "20", "--no-pager"],
            check=False,
        )
        sys.exit(1)

    print("ZeroClaw restarted." if was_active else "ZeroClaw started.")
    print(f"Gateway is running on port {GATEWAY_PORT}.")

    # Extract and display pairing code.
    code = extract_pairing_code()
    if code:
        print(f"\nPairing code: {code}")
        print("Enter this code in the ZeroClaw web UI to connect.")
    else:
        print("\nPairing code not found in logs. Check manually:")
        print(f"  journalctl -u {SERVICE_NAME} -n 30 --no-pager")


if __name__ == "__main__":
    main()
